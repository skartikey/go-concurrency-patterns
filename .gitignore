# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work

# JetBrains IDEs
.idea/

# Stray binaries created by `go build ./patterns/<name>` or `./examples/<name>`.
# Each one lands at the repo root with a name equal to the package's leaf dir.
# Use `go run ./patterns/<name>` or `go build -o /dev/null ./patterns/<name>`
# to avoid creating them. Add a new line here when adding a new pattern dir.
/bounded-downloader
/channel-range-close
/concurrency-limit-semaphore
/concurrent-fetcher
/context-cancel
/context-timeout
/errgroup
/fan-in
/fan-out
/generator
/graceful-shutdown
/job-queue-worker-pool
/mutex-vs-channel
/pipeline
/pubsub-broadcast
/rate-limit
/select-loop
/sequencing
/signal-handling
/timeout
/worker-pool